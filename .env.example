# MetricPOS Premium — Variables de entorno
# Copia este archivo como .env y rellena los valores

# PostgreSQL — Railway lo provee automáticamente como DATABASE_URL
DATABASE_URL=postgresql://usuario:contraseña@host:5432/metricpos_premium

# JWT Secret — cambiar por una clave larga y aleatoria
JWT_SECRET=MetricPOS_Premium_2026_HN_CambiarEsto

# Entorno
NODE_ENV=production

# Puerto (Railway lo inyecta automáticamente)
PORT=3000
